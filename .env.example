DATABASE_URL="postgresql://user:password@localhost:5432/sandbox_skins?schema=public"

# Upstash Redis (optional — cache falls through to Postgres if unset)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Steam + scraper secrets
STEAM_API_KEY="your_steam_api_key_here"
CRON_SECRET="your_cron_secret_here"

# Admin UI gate (also used for the tweet admin panel)
ANALYTICS_KEY="your_admin_key_here"

# Twitter/X — for scheduled + on-demand tweet posting
TWITTER_API_KEY=""
TWITTER_API_SECRET=""
TWITTER_ACCESS_TOKEN=""
TWITTER_ACCESS_TOKEN_SECRET=""

# Base URL (optional, defaults to sboxskins.gg)
NEXT_PUBLIC_BASE_URL="https://sboxskins.gg"
