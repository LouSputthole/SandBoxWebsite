generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id             String       @id @default(cuid())
  steamMarketId  String?      @unique
  name           String
  slug           String       @unique
  description    String?
  type           String       // "character", "clothing", "accessory", "weapon", "tool"
  imageUrl       String?
  marketUrl      String?
  steamItemNameId String?     // Steam numeric ID for order histogram (scraped locally)
  sboxFullIdent  String?      // Facepunch FullIdent (e.g. "estavos.cardboardking") — used to link to the specific sbox.game item page
  storeStatus    String       @default("unknown") // "available", "delisted", "unknown"
  delistedAt     DateTime?    // When the item was removed from the S&box store
  storePrice     Float?       // Original store price (if known)
  currentPrice   Float?
  lowestPrice    Float?
  medianPrice    Float?
  volume         Int?         @default(0)
  totalSupply    Int?         // Total units in existence (from S&box metrics)
  priceChange24h Float?       @default(0)
  isLimited      Boolean      @default(false)

  // --- sbox.dev enrichment ---
  releaseDate         DateTime?  // When the skin was first released
  releasePrice        Float?     // Original store price from sbox.dev
  uniqueOwners        Int?       // Distinct Steam accounts holding this item
  soldPast24h         Int?       // Units bought/sold in last 24h (from sbox.dev)
  supplyOnMarket      Int?       // Currently listed on Steam Community Market
  totalSales          Int?       // Lifetime total sales
  isActiveStoreItem   Boolean    @default(false) // Currently purchasable in the S&box store
  isPermanentStoreItem Boolean   @default(false) // Permanent (never rotates out)
  leavingStoreAt      DateTime?  // When this item leaves the store rotation
  itemDisplayName     String?    // Rarity/tier label (e.g. "Special", "Costume")
  category            String?    // Broad category from sbox.dev (e.g. "Accessories")
  itemSubType         String?    // Specific type from sbox.dev (e.g. "Hat", "Shirt")
  workshopId          String?    // Steam Workshop file ID
  priceChange6h       Float?     // 6-hour price delta
  priceChange6hPercent Float?    // 6-hour price delta %
  iconBackgroundColor String?    // Suggested background color for item icon
  topHolders          Json?      // Top 10 holders from supply-sources endpoint
  sboxSyncedAt        DateTime?  // When we last successfully pulled sbox.dev data for this item
  scarcityScore       Float?     // 0-100 composite score: distribution + liquidity + momentum

  supplySnapshots SupplySnapshot[]
  tradeListingItems TradeListingItem[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  priceHistory   PricePoint[]
  priceAlerts    PriceAlert[]

  @@index([type])
  @@index([currentPrice])
  @@index([storeStatus])
  @@index([isActiveStoreItem])
  @@index([sboxSyncedAt])
  @@index([scarcityScore])
}

model PricePoint {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  price     Float
  volume    Int?     @default(0)
  timestamp DateTime @default(now())

  @@index([itemId, timestamp])
}

model PriceAlert {
  id             String   @id @default(cuid())
  email          String?  // now optional — user may prefer only discord
  discordWebhook String?  // optional Discord webhook URL
  itemId         String
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  targetPrice    Float
  direction      String   // "below" or "above"
  active         Boolean  @default(true)
  triggered      Boolean  @default(false)
  triggeredAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([itemId, active])
  @@index([email])
  @@index([userId])
}

model SupplySnapshot {
  id           String   @id @default(cuid())
  itemId       String
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  totalSupply  Int
  uniqueOwners Int?
  price        Float?   // price at snapshot time, for context
  timestamp    DateTime @default(now())

  @@index([itemId, timestamp])
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  excerpt    String
  content    String   // markdown
  kind       String?  // "weekly-report", "market-analysis", "announcement"
  coverImage String?
  publishedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([publishedAt])
  @@index([kind])
}

model MarketSnapshot {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  totalItems    Int
  listingsValue Float    // sum(currentPrice * sellListings) — value of all active listings. (Renamed from marketCap — previous name was misleading.)
  estMarketCap  Float?   // NEW: sum(currentPrice * totalSupply) where supply is known — actual estimated market cap
  avgPrice      Float    // mean of currentPrice (items with price > 0)
  medianPrice   Float?   // true median of currentPrice
  totalVolume   Int      // sum of all active listings
  totalSupply   Int?     // sum of totalSupply across items that have it
  floor         Float?   // cheapest item price
  ceiling       Float?   // most expensive item price

  @@index([timestamp])
}

model User {
  id        String   @id @default(cuid())
  steamId   String   @unique
  username  String?
  avatarUrl String?
  profileUrl String?
  // Full Steam trade-offer URL (the form
  // "https://steamcommunity.com/tradeoffer/new/?partner=<accountID32>&token=<token>").
  // Required before the user can post a trade listing — the token portion
  // lets non-friends initiate trades. Cached here so users only paste it
  // once. Validated on write to ensure the partner derives from this user's
  // own steamId (prevents spoofing someone else's trade URL).
  steamTradeUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions       Session[]
  watchlistItems WatchlistItem[]
  priceAlerts    PriceAlert[]
  tradeListings  TradeListing[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemSlug  String
  createdAt DateTime @default(now())

  @@unique([userId, itemSlug])
  @@index([userId])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  country   String?
  city      String?
  device    String?  // "desktop", "mobile", "tablet"
  browser   String?
  os        String?
  sessionId String?  // anonymous session fingerprint (hashed IP + UA)
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([path])
  @@index([sessionId])
}

model ScheduledTweet {
  id               String   @id @default(cuid())
  text             String
  scheduledFor     DateTime
  status           String   @default("pending") // "pending" | "posted" | "failed" | "cancelled"
  kind             String?  // mirror of SentTweet.kind so we can categorize later
  itemSlug         String?
  inReplyToTweetId String?
  // Once posted, link back to the resulting SentTweet row
  postedTweetId    String?
  failureReason    String?
  attemptedAt      DateTime?
  createdAt        DateTime @default(now())

  @@index([status, scheduledFor])
  @@index([scheduledFor])
}

model SentTweet {
  id              String   @id @default(cuid())
  tweetId         String   @unique // X's numeric tweet ID
  text            String
  kind            String?  // top-gainer, top-loser, rarest, market-cap, item-spotlight, limited-edition, reply, custom
  itemSlug        String?  // item referenced in tweet (for click attribution)
  inReplyToTweetId String? // for replies
  sentAt          DateTime @default(now())

  @@index([sentAt])
  @@index([itemSlug])
}

model DailyStats {
  id          String   @id @default(cuid())
  date        DateTime @unique // one row per day
  views       Int      @default(0)
  visitors    Int      @default(0) // unique sessionIds
  topPages    Json?    // [{ path, count }]
  topReferrers Json?   // [{ referrer, count }]
  topCountries Json?   // [{ country, count }]

  @@index([date])
}

// ---------------------------------------------------------------------------
// Trade bulletin board — bulletin-style listings, no escrow, no custody.
// We just match users + deep-link to a Steam trade. See /trade pages.
// ---------------------------------------------------------------------------

model TradeListing {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "selling" = offering items, accepting cash/keys/anything
  // "buying"  = wanting items, paying with cash/keys/other items
  // "both"    = item-for-item trade with stuff on both sides
  side        String
  // Freeform description (e.g. "make an offer", "Trading for Rust Skins").
  description String
  // active → completed (owner mark) | cancelled (owner cancel) | expired (cron)
  status      String   @default("active")
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  // Default 14d, max 30d (enforced at the API layer). Cron flips status to
  // "expired" once now() > expiresAt.
  expiresAt   DateTime

  items TradeListingItem[]

  @@index([status, createdAt])
  @@index([status, expiresAt])
  @@index([userId, status])
  @@index([side, status])
}

model TradeListingItem {
  id         String   @id @default(cuid())
  listingId  String
  listing    TradeListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  // "offering" = on the poster's side / "wanting" = what they want in return
  slot       String
  // For in-catalog items, link to Item; otherwise customName captures
  // off-catalog stuff like "TF2 keys", "Rust skins", "$50 PayPal".
  itemId     String?
  item       Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  customName String?
  quantity   Int      @default(1)
  // Preserve the listing-time price so old listings don't quietly re-value
  // when an item moves on the market. Optional — only set for catalog items
  // that had a price at create time.
  unitPriceAtListing Float?

  @@index([listingId])
  @@index([itemId])
}
