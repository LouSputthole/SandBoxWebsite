generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id             String       @id @default(cuid())
  steamMarketId  String?      @unique
  name           String
  slug           String       @unique
  description    String?
  type           String       // "character", "clothing", "accessory", "weapon", "tool"
  rarity         String?      // "common", "uncommon", "rare", "legendary"
  imageUrl       String?
  marketUrl      String?
  steamItemNameId String?      // Steam numeric ID for order histogram (scraped locally)
  currentPrice   Float?
  lowestPrice    Float?
  medianPrice    Float?
  volume         Int?         @default(0)
  totalSupply    Int?         // Total units in existence (from S&box metrics)
  priceChange24h Float?       @default(0)
  isLimited      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  priceHistory   PricePoint[]
  priceAlerts    PriceAlert[]

  @@index([type])
  @@index([rarity])
  @@index([currentPrice])
}

model PricePoint {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  price     Float
  volume    Int?     @default(0)
  timestamp DateTime @default(now())

  @@index([itemId, timestamp])
}

model PriceAlert {
  id          String   @id @default(cuid())
  email       String
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  targetPrice Float
  direction   String   // "below" or "above"
  active      Boolean  @default(true)
  triggered   Boolean  @default(false)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())

  @@index([itemId, active])
  @@index([email])
}
