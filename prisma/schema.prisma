generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id             String       @id @default(cuid())
  steamMarketId  String?      @unique
  name           String
  slug           String       @unique
  description    String?
  type           String       // "character", "clothing", "accessory", "weapon", "tool"
  rarity         String?      // "common", "uncommon", "rare", "legendary"
  imageUrl       String?
  marketUrl      String?
  steamItemNameId String?      // Steam numeric ID for order histogram (scraped locally)
  storeStatus    String       @default("unknown") // "available", "delisted", "unknown"
  delistedAt     DateTime?    // When the item was removed from the S&box store
  storePrice     Float?       // Original store price (if known)
  currentPrice   Float?
  lowestPrice    Float?
  medianPrice    Float?
  volume         Int?         @default(0)
  totalSupply    Int?         // Total units in existence (from S&box metrics)
  priceChange24h Float?       @default(0)
  isLimited      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  priceHistory   PricePoint[]
  priceAlerts    PriceAlert[]

  @@index([type])
  @@index([rarity])
  @@index([currentPrice])
  @@index([storeStatus])
}

model PricePoint {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  price     Float
  volume    Int?     @default(0)
  timestamp DateTime @default(now())

  @@index([itemId, timestamp])
}

model PriceAlert {
  id          String   @id @default(cuid())
  email       String
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  targetPrice Float
  direction   String   // "below" or "above"
  active      Boolean  @default(true)
  triggered   Boolean  @default(false)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())

  @@index([itemId, active])
  @@index([email])
  @@index([userId])
}

model MarketSnapshot {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  totalItems  Int
  marketCap   Float    // sum(currentPrice * volume) across all items
  avgPrice    Float    // mean of currentPrice
  medianPrice Float?   // median of currentPrice
  totalVolume Int      // sum of all volumes (listings)
  totalSupply Int?     // sum of totalSupply across all items
  floor       Float?   // cheapest item price
  ceiling     Float?   // most expensive item price

  @@index([timestamp])
}

model User {
  id        String   @id @default(cuid())
  steamId   String   @unique
  username  String?
  avatarUrl String?
  profileUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions       Session[]
  watchlistItems WatchlistItem[]
  priceAlerts    PriceAlert[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemSlug  String
  createdAt DateTime @default(now())

  @@unique([userId, itemSlug])
  @@index([userId])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  country   String?
  city      String?
  device    String?  // "desktop", "mobile", "tablet"
  browser   String?
  os        String?
  sessionId String?  // anonymous session fingerprint (hashed IP + UA)
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([path])
  @@index([sessionId])
}

model DailyStats {
  id          String   @id @default(cuid())
  date        DateTime @unique // one row per day
  views       Int      @default(0)
  visitors    Int      @default(0) // unique sessionIds
  topPages    Json?    // [{ path, count }]
  topReferrers Json?   // [{ referrer, count }]
  topCountries Json?   // [{ country, count }]

  @@index([date])
}
