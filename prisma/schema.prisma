generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id             String       @id @default(cuid())
  steamMarketId  String?      @unique
  name           String
  slug           String       @unique
  description    String?
  type           String       // "character", "clothing", "accessory", "weapon", "tool"
  imageUrl       String?
  marketUrl      String?
  steamItemNameId String?     // Steam numeric ID for order histogram (scraped locally)
  steamItemNameIdCheckedAt DateTime? // Last nameid-scrape attempt — drives retry backoff so chronic failures don't starve new drops
  sboxFullIdent  String?      // Facepunch FullIdent (e.g. "estavos.cardboardking") — used to link to the specific sbox.game item page
  storeStatus    String       @default("unknown") // "available", "delisted", "unknown"
  delistedAt     DateTime?    // When the item was removed from the S&box store
  storePrice     Float?       // Original store price (if known)
  currentPrice   Float?
  lowestPrice    Float?
  medianPrice    Float?
  volume         Int?         @default(0)
  totalSupply    Int?         // Total units in existence (from S&box metrics)
  priceChange24h Float?       @default(0)
  isLimited      Boolean      @default(false)

  // --- sbox.dev enrichment ---
  releaseDate         DateTime?  // When the skin was first released
  releasePrice        Float?     // Original store price from sbox.dev
  uniqueOwners        Int?       // Distinct Steam accounts holding this item
  soldPast24h         Int?       // Units bought/sold in last 24h (from sbox.dev)
  supplyOnMarket      Int?       // Currently listed on Steam Community Market
  totalSales          Int?       // Lifetime total sales
  isActiveStoreItem   Boolean    @default(false) // Currently purchasable in the S&box store
  isPermanentStoreItem Boolean   @default(false) // Permanent (never rotates out)
  leavingStoreAt      DateTime?  // When this item leaves the store rotation
  itemDisplayName     String?    // Rarity/tier label (e.g. "Special", "Costume")
  category            String?    // Broad category from sbox.dev (e.g. "Accessories")
  itemSubType         String?    // Specific type from sbox.dev (e.g. "Hat", "Shirt")
  workshopId          String?    // Steam Workshop file ID
  priceChange6h       Float?     // 6-hour price delta
  priceChange6hPercent Float?    // 6-hour price delta %
  iconBackgroundColor String?    // Suggested background color for item icon
  topHolders          Json?      // Top 10 holders from supply-sources endpoint
  sboxSyncedAt        DateTime?  // When we last successfully pulled sbox.dev data for this item
  scarcityScore       Float?     // 0-100 composite score: distribution + liquidity + momentum
  // Steam Inventory Service item definition id. Surfaced by sbox.dev's
  // per-skin API as `itemDefinitionId`. Lets us fetch authoritative
  // store pricing from Steam's IGameInventory/GetItemDefArchive (the
  // same backend the in-game store reads from) instead of relying on
  // sbox.dev's releasePrice (often null for new drops).
  itemDefinitionId    Int?

  // Steam-sourced rarity color. Steam's market search/render feed returns
  // `asset_description.name_color` — a hex string (no leading '#', e.g.
  // "d32ce6") that Valve uses to tint the item name by rarity tier. Newer
  // S&box items carry one of a small CS-style palette; older/event items
  // (Wizard Hat, Pumpkin Head, …) return an empty string. We store the raw
  // hex ONLY when present, so the UI can render a rarity indicator strictly
  // for items that actually have one. There is NO human-readable rarity
  // *name* in Steam's payload for these items — `market_bucket_group_name`
  // just echoes the item's own name and there are no rarity `tags` — so we
  // deliberately store only the color and derive any display label client-
  // side from the known palette. Sourced directly from Steam, never sbox.dev.
  rarityColor         String?

  // --- Drop items (sbox.dev) ---
  // Some skins are random in-game drops rather than store purchases. sbox.dev
  // flags these as isDroppableItem with a droppedUnits count and a human-readable
  // rarity tier (common/uncommon/rare/exotic). Drops have no releasePrice — the
  // UI shows "Item Drop" instead of $0.00 (see src/lib/items/drop-label.ts).
  isDroppableItem     Boolean    @default(false)
  droppedUnits        Int?
  rarity              String?    // sbox.dev rarity tier (common/uncommon/rare/exotic/...)

  supplySnapshots SupplySnapshot[]
  tradeListingItems TradeListingItem[]
  marketListings MarketListing[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  priceHistory   PricePoint[]
  priceAlerts    PriceAlert[]

  @@index([type])
  @@index([currentPrice])
  @@index([storeStatus])
  @@index([isActiveStoreItem])
  @@index([sboxSyncedAt])
  @@index([scarcityScore])
  @@index([itemDefinitionId])
}

model PricePoint {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  price     Float
  volume    Int?     @default(0)
  timestamp DateTime @default(now())

  @@index([itemId, timestamp])
}

model PriceAlert {
  id             String   @id @default(cuid())
  email          String?  // now optional — user may prefer only discord
  discordWebhook String?  // optional Discord webhook URL
  itemId         String
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  targetPrice    Float
  direction      String   // "below" or "above"
  active         Boolean  @default(true)
  triggered      Boolean  @default(false)
  triggeredAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([itemId, active])
  @@index([email])
  @@index([userId])
}

model SupplySnapshot {
  id           String   @id @default(cuid())
  itemId       String
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  totalSupply  Int
  uniqueOwners Int?
  price        Float?   // price at snapshot time, for context
  timestamp    DateTime @default(now())

  @@index([itemId, timestamp])
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  excerpt    String
  content    String   // markdown
  kind       String?  // "weekly-report", "market-analysis", "announcement"
  coverImage String?
  publishedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([publishedAt])
  @@index([kind])
}

model MarketSnapshot {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  totalItems    Int
  listingsValue Float    // sum(currentPrice * sellListings) — value of all active listings. (Renamed from marketCap — previous name was misleading.)
  estMarketCap  Float?   // NEW: sum(currentPrice * totalSupply) where supply is known — actual estimated market cap
  avgPrice      Float    // mean of currentPrice (items with price > 0)
  medianPrice   Float?   // true median of currentPrice
  totalVolume   Int      // sum of all active listings
  totalSupply   Int?     // sum of totalSupply across items that have it
  floor         Float?   // cheapest item price
  ceiling       Float?   // most expensive item price

  @@index([timestamp])
}

model User {
  id        String   @id @default(cuid())
  steamId   String   @unique
  username  String?
  avatarUrl String?
  profileUrl String?
  // Full Steam trade-offer URL (the form
  // "https://steamcommunity.com/tradeoffer/new/?partner=<accountID32>&token=<token>").
  // Required before the user can post a trade listing — the token portion
  // lets non-friends initiate trades. Cached here so users only paste it
  // once. Validated on write to ensure the partner derives from this user's
  // own steamId (prevents spoofing someone else's trade URL).
  steamTradeUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions       Session[]
  watchlistItems WatchlistItem[]
  priceAlerts    PriceAlert[]
  tradeListings  TradeListing[]
  tradeComments  TradeComment[]
  loginEvents    LoginEvent[]
  notifications  Notification[]

  // --- marketplace (crypto escrow) ---
  wallet          UserWallet?
  steamCredential SellerSteamCredential?
  marketListings  MarketListing[] @relation("MarketListingSeller")
  buyerOrders     MarketOrder[]   @relation("MarketOrderBuyer")
  sellerOrders    MarketOrder[]   @relation("MarketOrderSeller")
  reviewsWritten  MarketReview[]  @relation("MarketReviewRater")
  reviewsReceived MarketReview[]  @relation("MarketReviewRated")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // SHA-256(ip + AUTH_HASH_SALT). We don't store raw IPs — the hash is
  // enough to detect "is this the same network as the one that created
  // the session" without keeping PII. Salt makes a DB leak useless for
  // rainbow-tabling addresses back. NULL only on legacy rows pre-rollout.
  ipHash    String?
  // First 200 chars of User-Agent. Bounded to keep the column tame.
  userAgent String?
  // Refreshed on every authenticated request so the /account/sessions
  // page can show "last seen 2m ago" instead of just "created 8 days ago".
  // Throttled in code to once per 60s to avoid hammering the DB.
  lastSeenAt DateTime @default(now())

  loginEvents LoginEvent[]

  @@index([token])
  @@index([userId])
  @@index([userId, lastSeenAt])
}

// ---------------------------------------------------------------------------
// Audit trail for security-relevant events on a Steam-authenticated account.
// Surfaced to the user on /account/sessions so they can spot anything
// suspicious themselves — we don't auto-revoke on anomaly because false
// positives (mobile IP roaming, Chrome version bumps) would train users
// to ignore the warnings.
// ---------------------------------------------------------------------------
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Optional FK to the session involved — null when the event happened
  // before a session existed (e.g. failed assertion verification).
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  // "login_success", "login_failure", "logout", "session_revoked",
  // "session_anomaly" (token used from a notably different ipHash + UA
  // combo than at create time).
  kind      String
  // Free-form context: failure reason, anomaly description, or "user
  // clicked logout-all". Not user-secret data.
  reason    String?
  ipHash    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([kind, createdAt])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemSlug  String
  createdAt DateTime @default(now())

  @@unique([userId, itemSlug])
  @@index([userId])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  // Full pathname of the referring URL (no query/hash), captured for
  // debugging which specific external pages send us traffic — e.g.
  // "/groups/sboxtraders" when steamcommunity.com is the referrer.
  // Separate from `referrer` so the main top-referrers aggregation
  // (grouped by normalized hostname) stays clean.
  referrerPath String?
  userAgent String?
  country   String?
  city      String?
  device    String?  // "desktop", "mobile", "tablet"
  browser   String?
  os        String?
  sessionId String?  // anonymous session fingerprint (hashed IP + UA)
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([path])
  @@index([sessionId])
}

model ScheduledTweet {
  id               String   @id @default(cuid())
  text             String
  scheduledFor     DateTime
  status           String   @default("pending") // "pending" | "posted" | "failed" | "cancelled"
  kind             String?  // mirror of SentTweet.kind so we can categorize later
  itemSlug         String?
  inReplyToTweetId String?
  // Once posted, link back to the resulting SentTweet row
  postedTweetId    String?
  failureReason    String?
  attemptedAt      DateTime?
  createdAt        DateTime @default(now())

  @@index([status, scheduledFor])
  @@index([scheduledFor])
}

model SentTweet {
  id              String   @id @default(cuid())
  tweetId         String   @unique // X's numeric tweet ID
  text            String
  kind            String?  // top-gainer, top-loser, rarest, market-cap, item-spotlight, limited-edition, reply, custom
  itemSlug        String?  // item referenced in tweet (for click attribution)
  inReplyToTweetId String? // for replies
  sentAt          DateTime @default(now())

  @@index([sentAt])
  @@index([itemSlug])
}

model DailyStats {
  id          String   @id @default(cuid())
  date        DateTime @unique // one row per day
  views       Int      @default(0)
  visitors    Int      @default(0) // unique sessionIds
  topPages    Json?    // [{ path, count }]
  topReferrers Json?   // [{ referrer, count }]
  topCountries Json?   // [{ country, count }]

  @@index([date])
}

// ---------------------------------------------------------------------------
// Trade bulletin board — bulletin-style listings, no escrow, no custody.
// We just match users + deep-link to a Steam trade. See /trade pages.
// ---------------------------------------------------------------------------

model TradeListing {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "selling" = offering items, accepting cash/keys/anything
  // "buying"  = wanting items, paying with cash/keys/other items
  // "both"    = item-for-item trade with stuff on both sides
  side        String
  // Freeform description (e.g. "make an offer", "Trading for Rust Skins").
  description String
  // active → completed (owner mark) | cancelled (owner cancel) | expired (cron)
  status      String   @default("active")
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  // Default 14d, max 30d (enforced at the API layer). Cron flips status to
  // "expired" once now() > expiresAt.
  expiresAt   DateTime

  items    TradeListingItem[]
  comments TradeComment[]

  @@index([status, createdAt])
  @@index([status, expiresAt])
  @@index([userId, status])
  @@index([side, status])
}

// ---------------------------------------------------------------------------
// Public comment thread on a TradeListing. Mirrors how every functioning
// trade community already works (TF2 Outpost, r/GlobalOffensiveTrade) —
// users drop "+rep, hit me on Discord: handle#1234" so traders can reach
// each other without us building real-time DMs.
//
// Steam OAuth required to post (handled at the API layer); soft-deleted
// rows stay in the table so an admin moderation history exists, and so
// reply context (e.g. "I deleted that one because…") doesn't lose anchor.
// ---------------------------------------------------------------------------
model TradeComment {
  id        String   @id @default(cuid())
  listingId String
  listing   TradeListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 1-1000 chars enforced at the API; stored as plaintext, rendered as
  // pre-wrap in JSX (no HTML or markdown — keeps the renderer dumb and
  // can't ship XSS).
  body      String
  createdAt DateTime @default(now())
  // Soft-delete: NULL = visible, set = hidden from UI. We keep the row so
  // moderation has an audit trail and so a deleted comment doesn't
  // re-orphan future "reply to" features.
  deletedAt DateTime?
  // Whoever clicked delete (the comment author themselves, or an admin).
  // Stored as a free string instead of a user FK so admin actions can
  // record "admin" without needing a User row for the operator.
  deletedBy String?

  @@index([listingId, createdAt])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// In-app notifications. One row per event delivered to one user — fan-out at
// write time, not read time, so the bell badge query is a cheap COUNT WHERE
// readAt IS NULL on a single user-keyed index.
//
// `payload` is intentionally JSON instead of FK columns: each notification
// kind ("trade_comment" today, "trade_offer" / "price_alert" tomorrow)
// carries its own shape, and we don't want a 12-nullable-column table when
// kinds expand. The kind+payload pair is what the renderer dispatches on.
// ---------------------------------------------------------------------------
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "trade_comment" — someone commented on a listing this user owns.
  // Future kinds can be added without schema changes; the renderer in
  // src/components/notifications/notification-bell.tsx narrows on this.
  kind      String
  // Shape depends on `kind`. For "trade_comment":
  //   { listingId, listingTitle, commentId, body (truncated 160 chars),
  //     fromUsername, fromAvatarUrl }
  payload   Json
  // NULL until the user sees it (clicks the bell or marks-all-read).
  // Indexed jointly with userId so the unread-count query is hot.
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model TradeListingItem {
  id         String   @id @default(cuid())
  listingId  String
  listing    TradeListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  // "offering" = on the poster's side / "wanting" = what they want in return
  slot       String
  // For in-catalog items, link to Item; otherwise customName captures
  // off-catalog stuff like "TF2 keys", "Rust skins", "$50 PayPal".
  itemId     String?
  item       Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  customName String?
  quantity   Int      @default(1)
  // Preserve the listing-time price so old listings don't quietly re-value
  // when an item moves on the market. Optional — only set for catalog items
  // that had a price at create time.
  unitPriceAtListing Float?

  @@index([listingId])
  @@index([itemId])
}

// ---------------------------------------------------------------------------
// Newsletter subscriptions. Two flavors (`kinds`): "friday-report" (weekly
// market wrap) and "monday-outlook" (forward-looking digest with momentum
// rankings). One row per email — users can be subscribed to both, neither,
// or either. Double-opt-in via verifyToken + one-click unsubscribe via a
// signed token in the link.
// ---------------------------------------------------------------------------

model NewsletterSubscription {
  id               String    @id @default(cuid())
  email            String    @unique
  // Which newsletters this address wants. Stored as a Postgres string[]
  // so we can query `"monday-outlook" = ANY("kinds")` efficiently at send
  // time without a join table (kinds are an enum-like closed set).
  kinds            String[]  @default(["monday-outlook"])
  // Opaque token placed in unsubscribe links. Rotating it invalidates old
  // links if an abuse report comes in — keeps us compliant without
  // rewriting every outgoing email.
  unsubscribeToken String    @unique
  // Double opt-in: unverified rows never receive mail. verifyToken is the
  // one-time confirmation token emailed after signup. NULL once verified.
  verified         Boolean   @default(false)
  verifyToken      String?   @unique
  createdAt        DateTime  @default(now())
  verifiedAt       DateTime?
  unsubscribedAt   DateTime?
  // Soft track of last send per kind so we don't double-send if a cron
  // replays. Stored as JSON { "monday-outlook": "2026-04-27T...", … }.
  lastSentAt       Json?

  @@index([verified])
  @@index([unsubscribedAt])
}

// ===========================================================================
// MARKETPLACE (crypto escrow) — spec: docs/superpowers/specs/2026-07-01-marketplace-design.md
// Real-money, non-custodial P2P escrow settling in USDC on Solana. Distinct from the
// barter-style TradeListing board above (that one moves no money). "Enum" fields are
// String + comment, matching the rest of this schema; the authoritative state machine
// lives in src/lib/market/escrow-state.ts.
//
// NB: the migration also adds guards Prisma can't express in-schema (raw SQL) — three
// PARTIAL UNIQUE indexes (one ACTIVE listing per steam asset; one LIVE order per listing; one
// LIVE order per steam asset — the double-spend backstops) and CHECK constraints (priceUsd/priceUsdc >= 0, feeBps 0..10000,
// buyer <> seller). See migrations/20260701134600_add_marketplace/migration.sql. Keep them when
// editing; `prisma migrate dev` won't round-trip them.
// ===========================================================================

// One Solana wallet per user: buyers fund escrow from it, sellers receive USDC to it.
model UserWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address   String // Solana wallet address (base58)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([address])
}

// Seller's Steam Web API key, AES-GCM encrypted at rest (see src/lib/market/steam-credential.ts).
// Lets the oracle read the seller's outgoing trade-offer status; the buyer side is covered by
// public inventory. Also records the Mobile-Authenticator requirement (no 15-day trade hold).
model SellerSteamCredential {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  encryptedApiKey     String // AES-GCM ciphertext (base64)
  iv                  String // base64
  authTag             String // base64
  mobileAuthConfirmed Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model MarketListing {
  id     String @id @default(cuid())
  sellerId String
  seller   User  @relation("MarketListingSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  // Snapshot of the exact Steam copy being sold (anti-scam / exact-item match).
  steamAssetId String
  classId      String
  instanceId   String

  priceUsd Float // display price; converted to USDC base units at buy time
  // "ACTIVE" | "SOLD" | "DELISTED" | "UNAVAILABLE" (seller no longer holds it)
  status   String @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders MarketOrder[]

  @@index([status])
  @@index([sellerId])
  @@index([itemId])
}

model MarketOrder {
  id        String        @id @default(cuid())
  listingId String
  listing   MarketListing @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User          @relation("MarketOrderBuyer", fields: [buyerId], references: [id])
  sellerId  String
  seller    User          @relation("MarketOrderSeller", fields: [sellerId], references: [id])

  // Price-agnostic settlement amount in USDC base units (6dp) — set at buy time from whatever
  // listing type agreed the price (fixed now; offers/auctions later, §6.5 seam). BigInt maps to
  // JS `bigint`, matching src/lib/market/fees.ts.
  priceUsdc BigInt
  feeBps    Int    @default(360)

  // On-chain escrow (Solana program). Null until the buyer's deposit tx confirms.
  // Unique: one escrow PDA maps to at most one order (nullable → many NULLs allowed).
  escrowPda      String? @unique
  onchainOrderId String? @unique

  // Public-trust-ledger proof-chain signatures (Solana tx signatures, base58). Best-effort: written
  // in the same money-write as the state change, but a missing one NEVER fails that write — they are
  // display-only proof links for /market/ledger. openTxSig = the buyer's open_escrow funding tx
  // (null on the mock/dev + reconcile paths); confirmTxSig = the authorizer confirm_delivery tx;
  // settleTxSig = the release/refund payout tx.
  openTxSig    String?
  confirmTxSig String?
  settleTxSig  String?

  // Per-party visibility on the PUBLIC ledger. Amounts + on-chain proof links stay visible either
  // way (the chain is public regardless); these flags gate ONLY the party's Steam identity (persona,
  // avatar, profile link) and — when either is false — the delivery-evidence Steam ids (trade-offer
  // id + delivered asset id, which could deanonymize an inventory). Default public.
  buyerPublic  Boolean @default(true)
  sellerPublic Boolean @default(true)

  // "PENDING" | "FUNDING" | "FUNDED" | "PROTECTION_HOLD" | "RELEASED" | "REFUNDED" | "DISPUTED"
  // (escrow-state.ts, MarketOrderState). PENDING = created but the buyer's on-chain open_escrow tx
  // hasn't confirmed yet (no escrow exists). FUNDING = a fund call atomically claimed the order and
  // is submitting/verifying the buyer's tx right now (stops a concurrent cancel from deleting the
  // row mid-confirm). Default PENDING: every order is born pre-funding and is promoted to FUNDED
  // only once funding verifies on-chain.
  state String @default("PENDING")

  // The exact item to deliver (copied from the listing snapshot).
  steamAssetId     String
  classId          String
  instanceId       String
  // The buyer's assetids of this class at order time. Delivery = a NEW assetid of the class
  // appears that isn't in this set — correct even if the buyer already owns identical copies
  // (prevents a seller getting paid off the buyer's pre-existing copy without ever sending).
  buyerPriorAssetIds String[]
  deliveredAssetId String? // the assetid that actually arrived (tracked for reversal)

  deliveryDeadline DateTime // seller must send the Steam trade by here, else buyer refund
  protectionUntil  DateTime? // payout releases after this (7-day Steam trade-protection window)

  // Lifecycle timestamps — fuel Phase-2 ratings + "avg time to accept" (§6.5 seam).
  // fundedAt is nullable + no default: it is set ONLY when on-chain funding verifies (order leaves
  // PENDING → FUNDED). A PENDING order has fundedAt = null.
  fundedAt            DateTime?
  sellerSentAt        DateTime?
  deliveredAt         DateTime?
  protectionStartedAt DateTime?
  releasedAt          DateTime?
  refundedAt          DateTime?

  disputeReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tradeAttempts TradeAttempt[]
  review        MarketReview?
  // Bans quick-issued from this order (buyer/seller ban from the dispute panel).
  bans          MarketBan[]

  @@index([state])
  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Buyer's rating of a seller after a COMPLETED (RELEASED) order. One review per
// order (orderId @unique) so rep can't be padded — every star is backed by a
// real, escrow-settled trade. Never fabricated: a review row only exists because
// a buyer actually rated a delivered order (enforced in review-service.ts +
// the API). The migration adds a CHECK (stars BETWEEN 1 AND 5) the schema can't
// express. onDelete Cascade on `order`: a review is meaningless without its
// order, and only terminal RELEASED orders (never deleted — funds have moved)
// can carry one, so the cascade is a correctness backstop that never fires in
// practice rather than a way to lose live rep.
// ---------------------------------------------------------------------------
model MarketReview {
  id      String      @id @default(cuid())
  orderId String      @unique
  order   MarketOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // The buyer who left the review.
  raterId String
  rater   User        @relation("MarketReviewRater", fields: [raterId], references: [id], onDelete: Cascade)
  // The seller being reviewed (rep accrues here).
  ratedId String
  rated   User        @relation("MarketReviewRated", fields: [ratedId], references: [id], onDelete: Cascade)
  // 1..5 — CHECK constraint in the migration (Prisma can't express it in-schema).
  stars   Int
  // Optional free-text, capped at 500 chars in the API. Rendered as plain text
  // (pre-wrap) in JSX — no HTML/markdown, same XSS-safe convention as TradeComment.
  comment   String?
  createdAt DateTime @default(now())

  @@index([ratedId, createdAt])
  @@index([raterId])
}

model TradeAttempt {
  id           String      @id @default(cuid())
  orderId      String
  order        MarketOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tradeOfferId String? // Steam trade-offer id from the seller's outgoing offer
  // "PENDING" | "SENT" | "ACCEPTED" | "DECLINED" | "EXPIRED" | "REVERSED" | "DISPUTED"
  status       String      @default("PENDING")
  evidence     Json? // raw oracle evidence (correlation verdict / hold-disappearance) for audit
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Marketplace ban list — makes the TOS §17 "ban a Steam id + wallet" promise
// real, enforced at every money-entry point (createOrder / createListing /
// createReview) via src/lib/market/bans.ts. A ban carries EITHER a steamId OR a
// walletAddress (or both) — at least one is required (the service enforces it;
// the migration adds a CHECK backstop). Both identifiers are recorded when known
// so a re-ban of either is idempotent, and a banned actor can't relink one to
// dodge (design §9 cross-identity tracking). A ban is ACTIVE while `liftedAt` IS
// NULL; lifting is a SOFT delete (keeps the ban history). The match identifiers
// are NOT FK-tied to a User row on purpose: we may need to ban a raw identifier
// we've seen abuse from even when no current User carries it (a wallet that
// funded a scam, a Steam id that hasn't signed up yet). `orderId` DOES FK to the
// triggering order (SET NULL) so a quick-ban keeps its provenance without ever
// blocking that order's deletion. The migration adds partial-unique indexes (one
// ACTIVE ban per identifier) the schema can't express in-line.
// ---------------------------------------------------------------------------
model MarketBan {
  id String @id @default(cuid())

  // Match identifiers, stored EXACTLY as elsewhere in the app (no case-folding):
  // steamId is the 64-bit string (User.steamId); walletAddress is base58 as-is
  // (UserWallet.address). At least one is set — service-enforced + DB CHECK.
  steamId       String?
  walletAddress String?

  reason String
  // Which admin key issued the ban — "analytics" | "cron" (guardAdminRoute.keyType).
  bannedByKeyType String
  // Optional link to the order that triggered the ban (quick-ban from a dispute).
  // SET NULL on order delete: ban history outlives the order it was born from.
  orderId String?
  order   MarketOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  // NULL = active. Set to the lift time on a soft-lift (history is never deleted).
  liftedAt  DateTime?

  @@index([steamId])
  @@index([walletAddress])
}
