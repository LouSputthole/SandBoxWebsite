generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id             String       @id @default(cuid())
  steamMarketId  String?      @unique
  name           String
  slug           String       @unique
  description    String?
  type           String       // "character", "clothing", "accessory", "weapon", "tool"
  imageUrl       String?
  marketUrl      String?
  steamItemNameId String?     // Steam numeric ID for order histogram (scraped locally)
  sboxFullIdent  String?      // Facepunch FullIdent (e.g. "estavos.cardboardking") — used to link to the specific sbox.game item page
  storeStatus    String       @default("unknown") // "available", "delisted", "unknown"
  delistedAt     DateTime?    // When the item was removed from the S&box store
  storePrice     Float?       // Original store price (if known)
  currentPrice   Float?
  lowestPrice    Float?
  medianPrice    Float?
  volume         Int?         @default(0)
  totalSupply    Int?         // Total units in existence (from S&box metrics)
  priceChange24h Float?       @default(0)
  isLimited      Boolean      @default(false)

  // --- sbox.dev enrichment ---
  releaseDate         DateTime?  // When the skin was first released
  releasePrice        Float?     // Original store price from sbox.dev
  uniqueOwners        Int?       // Distinct Steam accounts holding this item
  soldPast24h         Int?       // Units bought/sold in last 24h (from sbox.dev)
  supplyOnMarket      Int?       // Currently listed on Steam Community Market
  totalSales          Int?       // Lifetime total sales
  isActiveStoreItem   Boolean    @default(false) // Currently purchasable in the S&box store
  isPermanentStoreItem Boolean   @default(false) // Permanent (never rotates out)
  leavingStoreAt      DateTime?  // When this item leaves the store rotation
  itemDisplayName     String?    // Rarity/tier label (e.g. "Special", "Costume")
  category            String?    // Broad category from sbox.dev (e.g. "Accessories")
  itemSubType         String?    // Specific type from sbox.dev (e.g. "Hat", "Shirt")
  workshopId          String?    // Steam Workshop file ID
  priceChange6h       Float?     // 6-hour price delta
  priceChange6hPercent Float?    // 6-hour price delta %
  iconBackgroundColor String?    // Suggested background color for item icon
  topHolders          Json?      // Top 10 holders from supply-sources endpoint
  sboxSyncedAt        DateTime?  // When we last successfully pulled sbox.dev data for this item
  scarcityScore       Float?     // 0-100 composite score: distribution + liquidity + momentum

  supplySnapshots SupplySnapshot[]
  tradeListingItems TradeListingItem[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  priceHistory   PricePoint[]
  priceAlerts    PriceAlert[]

  @@index([type])
  @@index([currentPrice])
  @@index([storeStatus])
  @@index([isActiveStoreItem])
  @@index([sboxSyncedAt])
  @@index([scarcityScore])
}

model PricePoint {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  price     Float
  volume    Int?     @default(0)
  timestamp DateTime @default(now())

  @@index([itemId, timestamp])
}

model PriceAlert {
  id             String   @id @default(cuid())
  email          String?  // now optional — user may prefer only discord
  discordWebhook String?  // optional Discord webhook URL
  itemId         String
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  targetPrice    Float
  direction      String   // "below" or "above"
  active         Boolean  @default(true)
  triggered      Boolean  @default(false)
  triggeredAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([itemId, active])
  @@index([email])
  @@index([userId])
}

model SupplySnapshot {
  id           String   @id @default(cuid())
  itemId       String
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  totalSupply  Int
  uniqueOwners Int?
  price        Float?   // price at snapshot time, for context
  timestamp    DateTime @default(now())

  @@index([itemId, timestamp])
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  excerpt    String
  content    String   // markdown
  kind       String?  // "weekly-report", "market-analysis", "announcement"
  coverImage String?
  publishedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([publishedAt])
  @@index([kind])
}

model MarketSnapshot {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  totalItems    Int
  listingsValue Float    // sum(currentPrice * sellListings) — value of all active listings. (Renamed from marketCap — previous name was misleading.)
  estMarketCap  Float?   // NEW: sum(currentPrice * totalSupply) where supply is known — actual estimated market cap
  avgPrice      Float    // mean of currentPrice (items with price > 0)
  medianPrice   Float?   // true median of currentPrice
  totalVolume   Int      // sum of all active listings
  totalSupply   Int?     // sum of totalSupply across items that have it
  floor         Float?   // cheapest item price
  ceiling       Float?   // most expensive item price

  @@index([timestamp])
}

model User {
  id        String   @id @default(cuid())
  steamId   String   @unique
  username  String?
  avatarUrl String?
  profileUrl String?
  // Full Steam trade-offer URL (the form
  // "https://steamcommunity.com/tradeoffer/new/?partner=<accountID32>&token=<token>").
  // Required before the user can post a trade listing — the token portion
  // lets non-friends initiate trades. Cached here so users only paste it
  // once. Validated on write to ensure the partner derives from this user's
  // own steamId (prevents spoofing someone else's trade URL).
  steamTradeUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions       Session[]
  watchlistItems WatchlistItem[]
  priceAlerts    PriceAlert[]
  tradeListings  TradeListing[]
  tradeComments  TradeComment[]
  loginEvents    LoginEvent[]
  notifications  Notification[]
  buyerTrades    EscrowTrade[] @relation("EscrowTradeBuyer")
  sellerTrades   EscrowTrade[] @relation("EscrowTradeSeller")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // SHA-256(ip + AUTH_HASH_SALT). We don't store raw IPs — the hash is
  // enough to detect "is this the same network as the one that created
  // the session" without keeping PII. Salt makes a DB leak useless for
  // rainbow-tabling addresses back. NULL only on legacy rows pre-rollout.
  ipHash    String?
  // First 200 chars of User-Agent. Bounded to keep the column tame.
  userAgent String?
  // Refreshed on every authenticated request so the /account/sessions
  // page can show "last seen 2m ago" instead of just "created 8 days ago".
  // Throttled in code to once per 60s to avoid hammering the DB.
  lastSeenAt DateTime @default(now())

  loginEvents LoginEvent[]

  @@index([token])
  @@index([userId])
  @@index([userId, lastSeenAt])
}

// ---------------------------------------------------------------------------
// Audit trail for security-relevant events on a Steam-authenticated account.
// Surfaced to the user on /account/sessions so they can spot anything
// suspicious themselves — we don't auto-revoke on anomaly because false
// positives (mobile IP roaming, Chrome version bumps) would train users
// to ignore the warnings.
// ---------------------------------------------------------------------------
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Optional FK to the session involved — null when the event happened
  // before a session existed (e.g. failed assertion verification).
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  // "login_success", "login_failure", "logout", "session_revoked",
  // "session_anomaly" (token used from a notably different ipHash + UA
  // combo than at create time).
  kind      String
  // Free-form context: failure reason, anomaly description, or "user
  // clicked logout-all". Not user-secret data.
  reason    String?
  ipHash    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([kind, createdAt])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemSlug  String
  createdAt DateTime @default(now())

  @@unique([userId, itemSlug])
  @@index([userId])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  // Full pathname of the referring URL (no query/hash), captured for
  // debugging which specific external pages send us traffic — e.g.
  // "/groups/sboxtraders" when steamcommunity.com is the referrer.
  // Separate from `referrer` so the main top-referrers aggregation
  // (grouped by normalized hostname) stays clean.
  referrerPath String?
  userAgent String?
  country   String?
  city      String?
  device    String?  // "desktop", "mobile", "tablet"
  browser   String?
  os        String?
  sessionId String?  // anonymous session fingerprint (hashed IP + UA)
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([path])
  @@index([sessionId])
}

model ScheduledTweet {
  id               String   @id @default(cuid())
  text             String
  scheduledFor     DateTime
  status           String   @default("pending") // "pending" | "posted" | "failed" | "cancelled"
  kind             String?  // mirror of SentTweet.kind so we can categorize later
  itemSlug         String?
  inReplyToTweetId String?
  // Once posted, link back to the resulting SentTweet row
  postedTweetId    String?
  failureReason    String?
  attemptedAt      DateTime?
  createdAt        DateTime @default(now())

  @@index([status, scheduledFor])
  @@index([scheduledFor])
}

model SentTweet {
  id              String   @id @default(cuid())
  tweetId         String   @unique // X's numeric tweet ID
  text            String
  kind            String?  // top-gainer, top-loser, rarest, market-cap, item-spotlight, limited-edition, reply, custom
  itemSlug        String?  // item referenced in tweet (for click attribution)
  inReplyToTweetId String? // for replies
  sentAt          DateTime @default(now())

  @@index([sentAt])
  @@index([itemSlug])
}

model DailyStats {
  id          String   @id @default(cuid())
  date        DateTime @unique // one row per day
  views       Int      @default(0)
  visitors    Int      @default(0) // unique sessionIds
  topPages    Json?    // [{ path, count }]
  topReferrers Json?   // [{ referrer, count }]
  topCountries Json?   // [{ country, count }]

  @@index([date])
}

// ---------------------------------------------------------------------------
// Trade bulletin board — bulletin-style listings, no escrow, no custody.
// We just match users + deep-link to a Steam trade. See /trade pages.
// ---------------------------------------------------------------------------

model TradeListing {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "selling" = offering items, accepting cash/keys/anything
  // "buying"  = wanting items, paying with cash/keys/other items
  // "both"    = item-for-item trade with stuff on both sides
  side        String
  // Freeform description (e.g. "make an offer", "Trading for Rust Skins").
  description String
  // active → completed (owner mark) | cancelled (owner cancel) | expired (cron)
  status      String   @default("active")
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  // Default 14d, max 30d (enforced at the API layer). Cron flips status to
  // "expired" once now() > expiresAt.
  expiresAt   DateTime

  items        TradeListingItem[]
  comments     TradeComment[]
  escrowTrades EscrowTrade[]

  @@index([status, createdAt])
  @@index([status, expiresAt])
  @@index([userId, status])
  @@index([side, status])
}

// ---------------------------------------------------------------------------
// Public comment thread on a TradeListing. Mirrors how every functioning
// trade community already works (TF2 Outpost, r/GlobalOffensiveTrade) —
// users drop "+rep, hit me on Discord: handle#1234" so traders can reach
// each other without us building real-time DMs.
//
// Steam OAuth required to post (handled at the API layer); soft-deleted
// rows stay in the table so an admin moderation history exists, and so
// reply context (e.g. "I deleted that one because…") doesn't lose anchor.
// ---------------------------------------------------------------------------
model TradeComment {
  id        String   @id @default(cuid())
  listingId String
  listing   TradeListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 1-1000 chars enforced at the API; stored as plaintext, rendered as
  // pre-wrap in JSX (no HTML or markdown — keeps the renderer dumb and
  // can't ship XSS).
  body      String
  createdAt DateTime @default(now())
  // Soft-delete: NULL = visible, set = hidden from UI. We keep the row so
  // moderation has an audit trail and so a deleted comment doesn't
  // re-orphan future "reply to" features.
  deletedAt DateTime?
  // Whoever clicked delete (the comment author themselves, or an admin).
  // Stored as a free string instead of a user FK so admin actions can
  // record "admin" without needing a User row for the operator.
  deletedBy String?

  @@index([listingId, createdAt])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// In-app notifications. One row per event delivered to one user — fan-out at
// write time, not read time, so the bell badge query is a cheap COUNT WHERE
// readAt IS NULL on a single user-keyed index.
//
// `payload` is intentionally JSON instead of FK columns: each notification
// kind ("trade_comment" today, "trade_offer" / "price_alert" tomorrow)
// carries its own shape, and we don't want a 12-nullable-column table when
// kinds expand. The kind+payload pair is what the renderer dispatches on.
// ---------------------------------------------------------------------------
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // "trade_comment" — someone commented on a listing this user owns.
  // Future kinds can be added without schema changes; the renderer in
  // src/components/notifications/notification-bell.tsx narrows on this.
  kind      String
  // Shape depends on `kind`. For "trade_comment":
  //   { listingId, listingTitle, commentId, body (truncated 160 chars),
  //     fromUsername, fromAvatarUrl }
  payload   Json
  // NULL until the user sees it (clicks the bell or marks-all-read).
  // Indexed jointly with userId so the unread-count query is hot.
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model TradeListingItem {
  id         String   @id @default(cuid())
  listingId  String
  listing    TradeListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  // "offering" = on the poster's side / "wanting" = what they want in return
  slot       String
  // For in-catalog items, link to Item; otherwise customName captures
  // off-catalog stuff like "TF2 keys", "Rust skins", "$50 PayPal".
  itemId     String?
  item       Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  customName String?
  quantity   Int      @default(1)
  // Preserve the listing-time price so old listings don't quietly re-value
  // when an item moves on the market. Optional — only set for catalog items
  // that had a price at create time.
  unitPriceAtListing Float?

  @@index([listingId])
  @@index([itemId])
}

// ---------------------------------------------------------------------------
// Newsletter subscriptions. Two flavors (`kinds`): "friday-report" (weekly
// market wrap) and "monday-outlook" (forward-looking digest with momentum
// rankings). One row per email — users can be subscribed to both, neither,
// or either. Double-opt-in via verifyToken + one-click unsubscribe via a
// signed token in the link.
// ---------------------------------------------------------------------------

model NewsletterSubscription {
  id               String    @id @default(cuid())
  email            String    @unique
  // Which newsletters this address wants. Stored as a Postgres string[]
  // so we can query `"monday-outlook" = ANY("kinds")` efficiently at send
  // time without a join table (kinds are an enum-like closed set).
  kinds            String[]  @default(["monday-outlook"])
  // Opaque token placed in unsubscribe links. Rotating it invalidates old
  // links if an abuse report comes in — keeps us compliant without
  // rewriting every outgoing email.
  unsubscribeToken String    @unique
  // Double opt-in: unverified rows never receive mail. verifyToken is the
  // one-time confirmation token emailed after signup. NULL once verified.
  verified         Boolean   @default(false)
  verifyToken      String?   @unique
  createdAt        DateTime  @default(now())
  verifiedAt       DateTime?
  unsubscribedAt   DateTime?
  // Soft track of last send per kind so we don't double-send if a cron
  // replays. Stored as JSON { "monday-outlook": "2026-04-27T...", … }.
  lastSentAt       Json?

  @@index([verified])
  @@index([unsubscribedAt])
}

// ===========================================================================
// CRYPTO ESCROW (Phase 2 of CSFloat-style trade facilitation)
// ===========================================================================
// User flow:
//   1. Seller posts a TradeListing (existing model). Buyer hits "Buy with
//      crypto" → creates an EscrowTrade in pending_deposit state.
//   2. Bot sends a Steam trade offer to the seller asking for the item(s).
//      Seller accepts → state → awaiting_payment.
//   3. Buyer pays via Coinbase Commerce (USDC/BTC/ETH). Webhook fires →
//      state → payment_confirmed.
//   4. Bot sends item to buyer. Buyer accepts the offer → state → completed.
//      We trigger the seller payout (manual for v1, automated later).
//   5. Anything goes wrong → state → disputed (admin queue) or → refunded /
//      cancelled depending on which side defaulted.
//
// All sensitive bot credentials (Steam shared/identity secrets, API keys)
// stay in env vars, NOT the database. The DB only holds an opaque label
// for which bot handled which trade.
// ===========================================================================

// One row per buy-now action. Central state machine; every webhook,
// admin action, and bot poll updates this row.
model EscrowTrade {
  id          String   @id @default(cuid())
  // The original listing this trade is fulfilling. We snapshot the items
  // + price into this row at create time so a seller editing/cancelling
  // the listing mid-trade can't mutate what's owed.
  listingId   String
  listing     TradeListing @relation(fields: [listingId], references: [id], onDelete: Restrict)

  buyerId     String
  buyer       User     @relation("EscrowTradeBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  sellerId    String
  seller      User     @relation("EscrowTradeSeller", fields: [sellerId], references: [id], onDelete: Restrict)

  // Snapshot of what's being traded. JSON shape:
  // { offering: [{ itemId, name, slug, quantity, unitPriceAtListing }],
  //   wanting: [...] } — same shape as TradeListingItem rows but frozen.
  itemSnapshot Json

  // Pricing — locked at create time so market swings don't change what
  // the buyer owes between create and payment.
  priceUsd          Float    // total in USD at listing time
  // Crypto-side detail set after Coinbase Commerce charge created.
  // priceCryptoCurrency stays null until the buyer picks a currency in
  // the Commerce hosted-checkout step (USDC vs BTC vs ETH).
  priceCryptoCurrency String?
  priceCryptoAmount   String?  // String to preserve decimal precision

  // Our cut. Default 5% of priceUsd. Realized at payout time.
  feeUsd      Float

  // State machine. See state-machine.ts for valid transitions.
  // pending_deposit → awaiting_payment → payment_confirmed →
  //   completed | disputed | refunded | cancelled
  state       String   @default("pending_deposit")

  // Which bot account is holding the items in escrow for this trade.
  // FK so we can join easily, but bot creds live in env vars.
  botAccountId String?
  botAccount   EscrowBotAccount? @relation(fields: [botAccountId], references: [id])

  // Steam trade offer IDs — set as the bot acts. Helpful for support
  // ("the deposit offer was 1234567890, here's the link to it").
  depositTradeOfferId String?  // bot ← seller (item in)
  releaseTradeOfferId String?  // bot → buyer (item out)
  refundTradeOfferId  String?  // bot → seller (item back, on cancel)

  // Timestamps for each transition — easier to query than a separate
  // event log, and the only auditing we actually need at v1 scale.
  createdAt          DateTime  @default(now())
  depositedAt        DateTime?
  paidAt             DateTime?
  releasedAt         DateTime?
  completedAt        DateTime?
  disputedAt         DateTime?
  refundedAt         DateTime?
  cancelledAt        DateTime?

  // Soft-deadlines. If the seller doesn't deposit within depositDeadline
  // we cancel automatically. Same for buyer payment deadline.
  depositDeadline    DateTime
  paymentDeadline    DateTime?

  payment Payment?
  dispute Dispute?

  @@index([buyerId, state])
  @@index([sellerId, state])
  @@index([state, createdAt])
  @@index([listingId])
}

// One bot Steam account per row. We expect 2-4 bots load-balanced.
// Status flag drives bot selection — "active" bots are eligible for
// new trades; "banned" / "maintenance" are skipped until manually
// flipped back.
model EscrowBotAccount {
  id        String   @id @default(cuid())
  // Public Steam ID — fine to store in DB. Lets the bot worker find
  // its credentials in env vars by `BOT_<steamId>_SHARED_SECRET` etc.
  steamId   String   @unique
  // Display name shown in admin UI. Not the Steam username (which can
  // change); this is our internal handle.
  label     String
  status    String   @default("active") // "active" | "banned" | "maintenance"
  // Soft cap so we don't pile every active trade onto one bot. Bot
  // selection prefers the bot with fewest open trades under this cap.
  maxConcurrentTrades Int @default(20)

  // Optional metadata for ops: when we last verified the bot can log in.
  lastHealthcheckAt DateTime?
  lastHealthcheckOk Boolean?

  trades    EscrowTrade[]
  inventory BotInventoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// Items currently held in escrow by a bot. One row per asset (Steam's
// asset IDs are unique within a user's inventory). Lets the bot know
// "this asset is reserved for trade X, don't include it in any other
// release offer."
model BotInventoryItem {
  id           String   @id @default(cuid())
  botAccountId String
  botAccount   EscrowBotAccount @relation(fields: [botAccountId], references: [id], onDelete: Cascade)

  steamAssetId String   // Steam's per-asset unique ID
  marketHashName String // for matching with Item catalog
  itemSlug     String?  // resolved against our catalog if possible
  // Which trade this asset is reserved for. Null if the bot is holding
  // surplus inventory (rare but happens after a partial dispute).
  reservedForTradeId String?

  acquiredAt   DateTime @default(now())

  @@unique([botAccountId, steamAssetId])
  @@index([botAccountId, reservedForTradeId])
}

// Crypto payment record. One row per EscrowTrade once the buyer hits
// the Coinbase Commerce hosted checkout. Webhook events append to
// `webhookEvents` JSON for audit.
model Payment {
  id        String   @id @default(cuid())
  tradeId   String   @unique
  trade     EscrowTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  processor String   // "coinbase_commerce" (today). bitpay/etc later.
  // Coinbase Commerce charge id (e.g. "CHARGE_XYZ"). Used to look up
  // status via API and to verify webhook payloads belong to this trade.
  processorChargeId String  @unique
  // Hosted-checkout URL the buyer is redirected to. Stored so we can
  // resurrect the link if the user navigates away mid-flow.
  hostedUrl String?

  // "new" | "pending" | "confirmed" | "failed" | "expired" | "resolved"
  // — closely follows Coinbase Commerce's own enum.
  status    String   @default("new")
  // Final settled amount + currency, set when status=confirmed/resolved.
  amountSettled        String?
  currencySettled      String?

  // Append-only log of webhook events for audit. Each entry:
  // { type, timestamp, raw }. Full raw payload preserved so a
  // reconciliation script can replay state from scratch if needed.
  webhookEvents Json    @default("[]")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?

  @@index([status, createdAt])
}

// Manual-review queue. One row per disputed trade. Admins (lookup via
// ANALYTICS_KEY) close disputes by setting `resolution` and triggering
// the corresponding state transition on the parent trade.
model Dispute {
  id        String   @id @default(cuid())
  tradeId   String   @unique
  trade     EscrowTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  // Who opened it. "buyer" or "seller". System-opened disputes
  // (e.g. timeout from one side) record "system".
  openedBy  String
  // Free-form summary of the complaint. Capped at 4000 chars at API.
  reason    String
  // Admin's resolution note + how the trade was closed.
  // resolution: "released_to_buyer" | "refunded_to_buyer" |
  //   "returned_to_seller" | "split" | "rejected"
  resolution String?
  resolutionNote String?
  resolvedBy String?  // free-form admin handle, "lou" / "support1"

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([resolvedAt, createdAt])
}
